import java.util.Scanner;
class CalculosNaturales {
    public static void main(String[] args) {
        Scanner teclado = new Scanner(System.in);

        System.out.print("Introduzca la cantidad de números a procesar: ");
        int cantidadNumeros = teclado.nextInt();

        System.out.println("\nNum\t| Cuadrado\t| Cubo\t\t| Raíz Cuadrada");
        System.out.println("-------------------------------------------------------");
        for (int numeroActual = 1; numeroActual <= cantidadNumeros; numeroActual++) {
            
            long resultadoCuadrado = (long) numeroActual * numeroActual;
            long resultadoCubo     = (long) numeroActual * numeroActual * numeroActual;
            double resultadoRaiz   = Math.sqrt(numeroActual);

            String raizConDosDecimales = String.format("%,.2f", resultadoRaiz);

            System.out.println(numeroActual + "\t| " + 
                               resultadoCuadrado + "\t\t| " + 
                               resultadoCubo + "\t\t| " + 
                               raizConDosDecimales);
        }
        teclado.close();
    }
}
