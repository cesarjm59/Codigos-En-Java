import java.util.Scanner;
class RomanoDel1Al20 {
    public static void main(String[] args) {
        Scanner teclado = new Scanner(System.in);

        System.out.print("Ingrese un número entre 1 y 20: ");
        int numeroIngresado = teclado.nextInt();

        if (numeroIngresado < 1 || numeroIngresado > 20) {
            System.out.println("[Error] El número DEBE estar estrictamente entre 1 y 20.");
        } else {
            String resultadoRomano = obtenerRomanoPorCasos(numeroIngresado);
            System.out.println("El número " + numeroIngresado + " en romano es: " + resultadoRomano);
        }

        teclado.close();
    }

    public static String obtenerRomanoPorCasos(int numero) {
        switch (numero) {
            case 1:  return "I";
            case 2:  return "II";
            case 3:  return "III";
            case 4:  return "IV";
            case 5:  return "V";
            case 6:  return "VI";
            case 7:  return "VII";
            case 8:  return "VIII";
            case 9:  return "IX";
            case 10: return "X";
            case 11: return "XI";
            case 12: return "XII";
            case 13: return "XIII";
            case 14: return "XIV";
            case 15: return "XV";
            case 16: return "XVI";
            case 17: return "XVII";
            case 18: return "XVIII";
            case 19: return "XIX";
            case 20: return "XX";
            default: return "";
        }
    }
}
